    "import time\n",
    "import math\n",
    "\n",
    "def calculate_sin():\n",
    "    total = 0\n",
    "    for i in range(1, 361):\n",
    "        total = total + math.sin(i * math.pi / 180)\n",
    "    return total\n",
    "    \n",
    "start_time = time.time()\n",
    "for i in range(100):\n",
    "    calculate_sin()\n",
    "end_time = time.time()\n",
