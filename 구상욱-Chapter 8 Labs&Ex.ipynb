   "source": [
    "import datetime as dt\n",
    "loveday = dt.date(2019, 2, 14)\n",
    "print(f'춘향이와 몽룡이의 연애 시작일: {loveday.year}년 {loveday.month}월 {loveday.day}일')\n",
    "daylist = [100, 200, 500, 1000]\n",
    "for i in daylist:\n",
    "    plusday = dt.timedelta(days = i)\n",
    "    annday = plusday + loveday\n",
    "    print(f'{i}일 기념일: {annday.year}년 {annday.month}월 {annday.day}일')"
   ]
