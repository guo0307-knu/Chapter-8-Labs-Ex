    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1에서 1000000까지의 합을 구하는 시간:  0.0111초 \n"
     ]
    }
   ],
   "source": [
    "import time\n",
    "def sum1to1000000():\n",
    "    numlist = list(range(1,1000001))\n",
    "    start_time = time.time()\n",
    "    sum(numlist)\n",
    "    end_time = time.time()\n",
    "    gap = end_time - start_time\n",
    "    print(f'1에서 1000000까지의 합을 구하는 시간: {gap:7.4f}초 ')\n",
    "sum1to1000000()\n"
   ]
