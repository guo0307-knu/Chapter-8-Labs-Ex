     "text": [
      "1000000까지의 합을 100번 반복해서 구하는 시간:  4.8760초 \n"
     ]
    }
   ],
   "source": [
    "import time\n",
    "def sum1to1000000():\n",
    "    numlist = list(range(1,1000001))\n",
    "    sum(numlist)\n",
    "\n",
    "start_time = time.time()\n",
    "for i in range(100):\n",
    "    sum1to1000000()\n",
    "end_time = time.time()\n",
    "gap = end_time - start_time\n",
    "print(f'1000000까지의 합을 100번 반복해서 구하는 시간: {gap:7.4f}초 ')"
   ]
